{
    "version": "0.2.0",
    "configurations": [
        {
            // Debug tests
            "name": "Python: Debug Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "purpose": [
                "debug-test"
            ],
            "console": "internalConsole",
            "justMyCode": false,
            "presentation": {
                "hidden": true, // Only for tests inline
            },
            "env": {
                "PYTEST_ADDOPTS": "--no-cov" // Coverage prevents debugging
            }
        },
        {
            "name": "Dev",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "justMyCode": false,
            "program": "${workspaceFolder}/.venv/bin/project",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "ENV": "dev",
            },
            "windows": {
                "program": "${workspaceFolder}/.venv/Script/project.exe"
            }
        },
        {
            "name": "Experiment",
            "type": "debugpy",
            "request": "launch",
            "console": "integratedTerminal",
            "justMyCode": false,
            "program": "${workspaceFolder}/.venv/bin/project",
            "args": [
                "--config-name",
                "${input:experiment_name}"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "ENV": "dev",
            },
            "windows": {
                "program": "${workspaceFolder}/.venv/Script/project.exe"
            }
        }
    ],
    "inputs": [
        {
            "id": "experiment_name",
            "type": "promptString",
            "description": "Name of experiment configuration.",
            "default": "example"
        }
    ]
}
